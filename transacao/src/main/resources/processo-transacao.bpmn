<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                   id="Definitions_1"
                   targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:process id="processo-transacao" name="Processo de Transação Bancária" isExecutable="true">

    <!-- Evento de Início -->
    <bpmn:startEvent id="StartEvent_1" name="Iniciar Transação">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Task: Verificar Saldo -->
    <bpmn:serviceTask id="verificar-saldo"
                      name="Verificar Saldo"
                      camunda:type="external"
                      camunda:topic="verificar-saldo">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Gateway: Tem Saldo? -->
    <bpmn:exclusiveGateway id="Gateway_1" name="Tem saldo?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Sim</bpmn:outgoing>
      <bpmn:outgoing>Flow_Nao</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Task: Registrar Transação -->
    <bpmn:serviceTask id="registrar-transacao"
                      name="Registrar Transação"
                      camunda:type="external"
                      camunda:topic="registrar-transacao">
      <bpmn:incoming>Flow_Sim</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Gateway: Débito ou Crédito? -->
    <bpmn:exclusiveGateway id="Gateway_2" name="Débito ou Crédito?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Debito</bpmn:outgoing>
      <bpmn:outgoing>Flow_Credito</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Task: Atualizar Extrato -->
    <bpmn:serviceTask id="atualizar-extrato"
                      name="Atualizar Extrato"
                      camunda:type="external"
                      camunda:topic="atualizar-extrato">
      <bpmn:incoming>Flow_Debito</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Task: Atualizar Fatura -->
    <bpmn:serviceTask id="atualizar-fatura"
                      name="Atualizar Fatura"
                      camunda:type="external"
                      camunda:topic="atualizar-fatura">
      <bpmn:incoming>Flow_Credito</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Gateway de Convergência -->
    <bpmn:exclusiveGateway id="Gateway_3">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:incoming>Flow_Nao</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Task: Notificar Solicitante -->
    <bpmn:serviceTask id="notificar-solicitante"
                      name="Notificar Solicitante"
                      camunda:type="external"
                      camunda:topic="notificar-solicitante">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Evento de Fim -->
    <bpmn:endEvent id="EndEvent_1" name="Transação Finalizada">
      <bpmn:incoming>Flow_7</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Fluxos de Sequência -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="verificar-saldo" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="verificar-saldo" targetRef="Gateway_1" />

    <bpmn:sequenceFlow id="Flow_Sim" name="Sim" sourceRef="Gateway_1" targetRef="registrar-transacao">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${temSaldo == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_Nao" name="Não" sourceRef="Gateway_1" targetRef="Gateway_3">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${temSaldo == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_3" sourceRef="registrar-transacao" targetRef="Gateway_2" />

    <bpmn:sequenceFlow id="Flow_Debito" name="Débito" sourceRef="Gateway_2" targetRef="atualizar-extrato">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${tipo == 'DEBITO'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_Credito" name="Crédito" sourceRef="Gateway_2" targetRef="atualizar-fatura">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${tipo == 'CREDITO'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_4" sourceRef="atualizar-extrato" targetRef="Gateway_3" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="atualizar-fatura" targetRef="Gateway_3" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Gateway_3" targetRef="notificar-solicitante" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="notificar-solicitante" targetRef="EndEvent_1" />

  </bpmn:process>

  <!-- Diagrama (posicionamento visual) -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="processo-transacao">
      <!-- Posições dos elementos (gerado automaticamente pelo Camunda Modeler) -->
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>