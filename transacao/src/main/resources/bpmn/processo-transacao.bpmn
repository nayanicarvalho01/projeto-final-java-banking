<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_1"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="Camunda Modeler"
                  exporterVersion="5.0.0">

  <bpmn:process id="processo-transacao" name="Processo de Transação" isExecutable="true">

    <bpmn:startEvent id="StartEvent" name="Transação Aprovada">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="RegistrarTransacao" name="Registrar Transação"
                      camunda:type="external"
                      camunda:topic="registrar-transacao">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_Tipo" name="Débito?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Debito</bpmn:outgoing>
      <bpmn:outgoing>Flow_Credito</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="AtualizarExtrato" name="Atualizar Extrato"
                      camunda:type="external"
                      camunda:topic="atualizar-extrato">
      <bpmn:incoming>Flow_Debito</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="AtualizarFatura" name="Atualizar Fatura"
                      camunda:type="external"
                      camunda:topic="atualizar-fatura">
      <bpmn:incoming>Flow_Credito</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_Merge">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="NotificarSolicitante" name="Notificar Solicitante"
                      camunda:type="external"
                      camunda:topic="notificar-solicitante">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent" name="Finalizado">
      <bpmn:incoming>Flow_6</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent" targetRef="RegistrarTransacao"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="RegistrarTransacao" targetRef="Gateway_Tipo"/>

    <bpmn:sequenceFlow id="Flow_Debito" name="Débito" sourceRef="Gateway_Tipo" targetRef="AtualizarExtrato">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${tipo == 'DEBITO'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_Credito" name="Crédito" sourceRef="Gateway_Tipo" targetRef="AtualizarFatura">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${tipo == 'CREDITO'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_3" sourceRef="AtualizarExtrato" targetRef="Gateway_Merge"/>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="AtualizarFatura" targetRef="Gateway_Merge"/>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Gateway_Merge" targetRef="NotificarSolicitante"/>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="NotificarSolicitante" targetRef="EndEvent"/>

  </bpmn:process>

  <!-- BPMN Diagram (opcional - apenas visual) -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="processo-transacao">

      <bpmndi:BPMNShape id="StartEvent_di" bpmnElement="StartEvent">
        <dc:Bounds x="152" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="RegistrarTransacao_di" bpmnElement="RegistrarTransacao">
        <dc:Bounds x="240" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_Tipo_di" bpmnElement="Gateway_Tipo" isMarkerVisible="true">
        <dc:Bounds x="395" y="95" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="AtualizarExtrato_di" bpmnElement="AtualizarExtrato">
        <dc:Bounds x="500" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="AtualizarFatura_di" bpmnElement="AtualizarFatura">
        <dc:Bounds x="500" y="200" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_Merge_di" bpmnElement="Gateway_Merge" isMarkerVisible="true">
        <dc:Bounds x="655" y="95" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="NotificarSolicitante_di" bpmnElement="NotificarSolicitante">
        <dc:Bounds x="760" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_di" bpmnElement="EndEvent">
        <dc:Bounds x="912" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Edges -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="188" y="120"/>
        <di:waypoint x="240" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="340" y="120"/>
        <di:waypoint x="395" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Debito_di" bpmnElement="Flow_Debito">
        <di:waypoint x="445" y="120"/>
        <di:waypoint x="500" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Credito_di" bpmnElement="Flow_Credito">
        <di:waypoint x="420" y="145"/>
        <di:waypoint x="420" y="240"/>
        <di:waypoint x="500" y="240"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="600" y="120"/>
        <di:waypoint x="655" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="600" y="240"/>
        <di:waypoint x="680" y="240"/>
        <di:waypoint x="680" y="145"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="705" y="120"/>
        <di:waypoint x="760" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="860" y="120"/>
        <di:waypoint x="912" y="120"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>